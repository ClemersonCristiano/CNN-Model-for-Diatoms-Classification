#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f -- "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd -- "$(dirname -- "${SCRIPT_PATH}")" && pwd)"
REPO_DIR="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

usage() {
  echo "Uso: run diatoms [args-do-uvicorn]"
  echo "Exemplo: run diatoms"
}

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

command_name="$1"
shift

case "${command_name}" in
  diatoms)
    cd "${REPO_DIR}"

    unset CLOUDFLARE_ACCOUNT_ID
    unset R2_ACCESS_KEY_ID
    unset R2_SECRET_ACCESS_KEY

    if [[ -x "${REPO_DIR}/venv/bin/python" ]]; then
      exec "${REPO_DIR}/venv/bin/python" -m uvicorn api.main:app --host 0.0.0.0 --port 7860 --reload "$@"
    fi

    exec python3 -m uvicorn api.main:app --host 0.0.0.0 --port 7860 --reload "$@"
    ;;
  *)
    usage
    exit 1
    ;;
esac
